# === LOCATION ===
LATITUDE=63.83
LONGITUDE=20.26
TIMEZONE=Europe/Stockholm

# === NTFY ===
NTFY_URL=https://your-ntfy-server.example.com
NTFY_TOPIC=migraines
NTFY_TOKEN=
NTFY_USERNAME=
NTFY_PASSWORD=
# Link opened when tapping notification (phone app URL)
APP_URL=http://192.168.1.10:8765

# === ALERT THRESHOLDS ===
RAPID_DROP_HPA=3
RAPID_DROP_HOURS=3
SUSTAINED_DROP_HPA=6
SUSTAINED_DROP_HOURS=12
RISE_RECOVERY_HPA=2
RISE_RECOVERY_HOURS=3

# Seasonal overrides (Dec–Feb / Jun–Aug); leave equal to defaults to disable effect
WINTER_RAPID_DROP_HPA=3
WINTER_SUSTAINED_DROP_HPA=6
SUMMER_RAPID_DROP_HPA=3
SUMMER_SUSTAINED_DROP_HPA=6

# Smoothed alerts (average over N hours — reduces false alarms)
SMOOTHING_HOURS=3
PRE_ALERT_ENABLED=true
WATCH_DROP_FRACTION=0.5
PRE_ALERT_COOLDOWN_HOURS=6

# Quiet hours (no routine alerts; deadman still fires)
QUIET_HOURS_ENABLED=true
QUIET_START=22:00
QUIET_END=07:00

# Deadman: notify if polls stop updating heartbeat
DEADMAN_ALERT_ENABLED=true
DEADMAN_STALE_HOURS=2
DEADMAN_CHECK_MINUTES=30
DEADMAN_COOLDOWN_HOURS=24

# === BEHAVIOUR ===
POLL_INTERVAL_MINUTES=60
LOG_RETENTION_DAYS=30
DATA_DIR=/data

# === API (phone app) ===
API_PORT=8780
API_TOKEN=
# Set true on home server and set API_TOKEN for LAN security
REQUIRE_API_TOKEN=false
