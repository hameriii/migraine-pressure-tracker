# === LOCATION ===
LATITUDE=63.83
LONGITUDE=20.26
TIMEZONE=Europe/Stockholm

# === NTFY ===
NTFY_URL=https://your-ntfy-server.example.com
NTFY_TOPIC=migraines
# If your ntfy requires auth, set ONE of these (leave the other blank):
NTFY_TOKEN=
NTFY_USERNAME=
NTFY_PASSWORD=

# === ALERT THRESHOLDS (tune to your experience) ===
RAPID_DROP_HPA=3
RAPID_DROP_HOURS=3
SUSTAINED_DROP_HPA=6
SUSTAINED_DROP_HOURS=12
RISE_RECOVERY_HPA=2
RISE_RECOVERY_HOURS=3

# === BEHAVIOUR ===
POLL_INTERVAL_MINUTES=60
LOG_RETENTION_DAYS=30
DATA_DIR=/data

# === MIGRAINE LOG API (phone app sync) ===
API_PORT=8780
# Optional: set a secret token; app must send Authorization: Bearer <token>
API_TOKEN=
